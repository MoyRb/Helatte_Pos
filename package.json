{
  "name": "helatte-pos",
  "version": "0.1.0",
  "description": "Helatte POS",
  "author": "Helatte",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:preload": "tsc -p tsconfig.preload.json --watch",
    "dev:renderer": "cd src/renderer && vite --port 5173",
    "dev:electron": "wait-on tcp:5173 file:dist/main/index.js file:dist/preload/index.js && electron .",
    "dev": "concurrently -k \"npm:dev:main\" \"npm:dev:preload\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "build:prisma": "prisma generate",
    "build:renderer": "cd src/renderer && vite build",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:prisma && npm run build:renderer && npm run build:preload && npm run build:main",
    "dist": "npm run build && electron-builder",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.16.2",
    "lucide-react": "^0.562.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.2",
    "recharts": "^3.6.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "29.4.0",
    "electron-builder": "24.13.3",
    "postcss": "^8.4.47",
    "prisma": "5.16.2",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^5.0.12",
    "wait-on": "^8.0.1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "build": {
    "appId": "com.helatte.pos",
    "productName": "Helatte POS",
    "asar": true,
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "node_modules/@prisma",
        "to": "node_modules/@prisma"
      },
      {
        "from": "node_modules/.prisma",
        "to": "node_modules/.prisma"
      },
      {
        "from": "prisma/helatte.db",
        "to": "prisma/helatte.db"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  }
}
