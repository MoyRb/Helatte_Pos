generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Brand {
  id          Int                 @id @default(autoincrement())
  slug        String              @unique
  nombre      String
  subtitulo   String?
  logoPath    String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  cashBoxes   CashBox[]
  cashMoves   CashMovement[]
  credits     Credit[]
  customers   Customer[]
  customerMovements CustomerMovement[]
  finishedStockMoves FinishedStockMovement[]
  flavors     Flavor[]
  fridgeAssets FridgeAsset[]
  fridgeAssignments FridgeAssignment[]
  fridgeVisits FridgeVisit[]
  productTypes ProductType[]
  products    Product[]
  productionPlans ProductionPlan[]
  promissoryNotes PromissoryNote[]
  rawMaterials RawMaterial[]
  rawMaterialMovements RawMaterialMovement[]
  sales       Sale[]
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  nombre    String
  password  String
  role      String   @default("CAJERO")
  createdAt DateTime @default(now())

  logs  AuditLog[]
  sales Sale[]
}

model Flavor {
  id       Int       @id @default(autoincrement())
  brandId  Int
  nombre   String
  color    String?
  activo   Boolean   @default(true)
  products Product[]
  brand    Brand     @relation(fields: [brandId], references: [id])

  @@index([brandId], map: "flavor_brand_idx")
}

model ProductType {
  id       Int       @id @default(autoincrement())
  brandId  Int
  nombre   String
  activo   Boolean   @default(true)
  products Product[]
  brand    Brand     @relation(fields: [brandId], references: [id])

  @@index([brandId], map: "producttype_brand_idx")
}

model Product {
  id            Int                    @id @default(autoincrement())
  brandId       Int
  sku           String?
  tipoId        Int
  saborId       Int
  presentacion  String
  precio        Float
  precioMayoreo Float?
  costo         Float
  foto          String?
  stock         Int                    @default(0)
  activo        Boolean                @default(true)

  brand           Brand                  @relation(fields: [brandId], references: [id])
  recipe          Recipe?
  tipo            ProductType            @relation(fields: [tipoId], references: [id])
  sabor           Flavor                 @relation(fields: [saborId], references: [id])
  items           SaleItem[]
  stockMoves      FinishedStockMovement[]
  productionItems ProductionPlanItem[]

  @@index([brandId], map: "product_brand_idx")
  @@unique([brandId, sku], map: "product_brand_sku_key")
}

model Unit {
  id       Int           @id @default(autoincrement())
  nombre   String        @unique
  materias RawMaterial[]
}

model RawMaterial {
  id        Int    @id @default(autoincrement())
  brandId   Int
  nombre    String
  unidadId  Int
  stock     Float  @default(0)
  costoProm Float  @default(0)

  brand       Brand                @relation(fields: [brandId], references: [id])
  unidad      Unit                 @relation(fields: [unidadId], references: [id])
  movimientos RawMaterialMovement[]
  recipeItems RecipeItem[]

  @@index([brandId], map: "rawmaterial_brand_idx")
}

model RawMaterialMovement {
  id         Int      @id @default(autoincrement())
  brandId    Int
  materialId Int
  tipo       String
  cantidad   Float
  costoTotal Float
  createdAt  DateTime @default(now())

  brand    Brand       @relation(fields: [brandId], references: [id])
  material RawMaterial @relation(fields: [materialId], references: [id])

  @@index([brandId], map: "rawmaterialmovement_brand_idx")
}

model FinishedStockMovement {
  id         Int      @id @default(autoincrement())
  brandId    Int
  productId  Int
  tipo       String
  cantidad   Int
  referencia String?
  createdAt  DateTime @default(now())

  brand   Brand   @relation(fields: [brandId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@index([brandId], map: "finishedstockmovement_brand_idx")
}

model Recipe {
  id        Int          @id @default(autoincrement())
  productId Int          @unique
  items     RecipeItem[]

  product Product @relation(fields: [productId], references: [id])
}

model RecipeItem {
  id         Int   @id @default(autoincrement())
  recipeId   Int
  materialId Int
  cantidad   Float

  recipe   Recipe      @relation(fields: [recipeId], references: [id])
  material RawMaterial @relation(fields: [materialId], references: [id])
}

model Sale {
  id             Int      @id @default(autoincrement())
  brandId        Int
  folio          String
  fecha          DateTime @default(now())
  cajeroId       Int
  customerId     Int?
  tipoVenta      String   @default("MOSTRADOR")
  subtotal       Float    @default(0)
  descuentoTipo  String   @default("ninguno")
  descuentoValor Float    @default(0)
  total          Float
  pagoMetodo     String

  brand  Brand     @relation(fields: [brandId], references: [id])
  items  SaleItem[]
  pagos  Payment[]
  cajero User      @relation(fields: [cajeroId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@index([brandId], map: "sale_brand_idx")
  @@index([fecha], map: "sale_fecha_idx")
  @@unique([brandId, folio], map: "sale_brand_folio_key")
}

model SaleItem {
  id            Int   @id @default(autoincrement())
  saleId        Int
  productId     Int
  cantidad      Int
  precio        Float
  subtotalLinea Float @default(0)

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Payment {
  id        Int      @id @default(autoincrement())
  saleId    Int
  monto     Float
  metodo    String
  createdAt DateTime @default(now())

  sale Sale @relation(fields: [saleId], references: [id])
}

model CashBox {
  id          Int            @id @default(autoincrement())
  brandId     Int
  nombre      String
  tipo        String
  brand       Brand          @relation(fields: [brandId], references: [id])
  movimientos CashMovement[]

  @@index([brandId], map: "cashbox_brand_idx")
}

model CashMovement {
  id        Int      @id @default(autoincrement())
  brandId   Int
  cashBoxId Int
  tipo      String
  concepto  String
  monto     Float
  fecha     DateTime @default(now())

  brand   Brand   @relation(fields: [brandId], references: [id])
  cashBox CashBox @relation(fields: [cashBoxId], references: [id])

  @@index([brandId], map: "cashmovement_brand_idx")
  @@index([cashBoxId], map: "cashmovement_cashbox_idx")
  @@index([fecha], map: "cashmovement_fecha_idx")
}

model Customer {
  id              Int     @id @default(autoincrement())
  brandId         Int
  nombre          String
  telefono        String?
  limite          Float   @default(0)
  saldo           Float   @default(0)
  estado          String  @default("activo")
  permiteMayoreo  Boolean @default(true)

  brand        Brand              @relation(fields: [brandId], references: [id])
  creditos     Credit[]
  pagares      PromissoryNote[]
  asignaciones FridgeAssignment[]
  movimientos  CustomerMovement[]
  sales        Sale[]

  @@index([brandId], map: "customer_brand_idx")
}

model Credit {
  id         Int      @id @default(autoincrement())
  brandId    Int
  customerId Int
  saldo      Float
  createdAt  DateTime @default(now())

  brand    Brand           @relation(fields: [brandId], references: [id])
  pagos    CreditPayment[]
  customer Customer        @relation(fields: [customerId], references: [id])

  @@index([brandId], map: "credit_brand_idx")
  @@index([customerId], map: "credit_customer_idx")
}

model CreditPayment {
  id       Int      @id @default(autoincrement())
  creditId Int
  monto    Float
  fecha    DateTime @default(now())

  credit Credit @relation(fields: [creditId], references: [id])
}

model PromissoryNote {
  id         Int      @id @default(autoincrement())
  brandId    Int
  customerId Int
  monto      Float
  fecha      DateTime @default(now())
  estado     String   @default("vigente")

  brand    Brand                @relation(fields: [brandId], references: [id])
  customer Customer             @relation(fields: [customerId], references: [id])
  abonos   PromissoryPayment[]

  @@index([brandId], map: "promissorynote_brand_idx")
}

model FridgeAsset {
  id           Int                @id @default(autoincrement())
  brandId      Int
  modelo       String
  serie        String
  estado       String
  brand        Brand              @relation(fields: [brandId], references: [id])
  visitas      FridgeVisit[]
  asignaciones FridgeAssignment[]

  @@index([brandId], map: "fridgeasset_brand_idx")
}

model FridgeAssignment {
  id          Int      @id @default(autoincrement())
  brandId     Int
  assetId     Int
  customerId  Int
  ubicacion   String
  entregadoEn DateTime
  fechaFin    DateTime?
  deposito    Float?
  renta       Float?

  brand    Brand       @relation(fields: [brandId], references: [id])
  asset    FridgeAsset @relation(fields: [assetId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])

  @@index([brandId], map: "fridgeassignment_brand_idx")
}

model FridgeVisit {
  id      Int      @id @default(autoincrement())
  brandId Int
  assetId Int
  fecha   DateTime @default(now())
  notas   String?

  brand Brand @relation(fields: [brandId], references: [id])
  items FridgeVisitItem[]
  asset FridgeAsset       @relation(fields: [assetId], references: [id])

  @@index([brandId], map: "fridgevisit_brand_idx")
}

model FridgeVisitItem {
  id       Int    @id @default(autoincrement())
  visitId  Int
  product  String
  cantidad Int
  devuelto Int

  visit FridgeVisit @relation(fields: [visitId], references: [id])
}

model ProductionPlan {
  id        Int                  @id @default(autoincrement())
  brandId   Int
  fecha     DateTime
  notas     String?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  brand Brand @relation(fields: [brandId], references: [id])
  items ProductionPlanItem[]

  @@index([brandId], map: "productionplan_brand_idx")
  @@unique([brandId, fecha], map: "productionplan_brand_fecha_key")
}

model ProductionPlanItem {
  id               Int            @id @default(autoincrement())
  planId           Int
  productId        Int?
  nombre           String
  presentacion     String
  cantidadBase     Int            @default(0)
  cantidadAjuste   Int            @default(0)
  cantidadAplicada Int            @default(0)
  orden            Int            @default(0)

  plan    ProductionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  product Product?       @relation(fields: [productId], references: [id])

  @@index([planId], map: "productionplanitem_plan_idx")
  @@index([productId], map: "productionplanitem_product_idx")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  modulo    String
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

model CustomerMovement {
  id         Int      @id @default(autoincrement())
  brandId    Int
  customerId Int
  tipo       String
  concepto   String
  monto      Float
  referencia String?
  createdAt  DateTime @default(now())

  brand    Brand    @relation(fields: [brandId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([brandId], map: "customermovement_brand_idx")
  @@index([customerId], map: "customermovement_customer_idx")
}

model PromissoryPayment {
  id               Int      @id @default(autoincrement())
  promissoryNoteId Int
  monto            Float
  fecha            DateTime @default(now())

  promissoryNote PromissoryNote @relation(fields: [promissoryNoteId], references: [id])

  @@index([promissoryNoteId], map: "promissorypayment_note_idx")
}
